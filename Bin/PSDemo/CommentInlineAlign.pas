{       Script Name: CommentInLineAlign                 }
{       Description: 俴囀蛁庋勤ょ                       }
{       Align // comments in selected lines             }
{                                                       }
{       Usage: Select multi-line code with inline       }
{       comments in editor, run the script to align     }
{       all // comments to the same column position.    }
{                                                       }
{*******************************************************}

program CommentInLineAlign;

uses
  Windows, SysUtils, Classes, CnWizIdeUtils;

var
  Lines: TStringList;
  I, FirstCommentIdx, CommentIdx, TargetPos, CodeLen: Integer;
  ALine, CodePart, CommentPart: string;
  CommentPos: array of Integer;
begin
  Lines := TStringList.Create;
  try
    if not IdeGetEditorSelectedLines(Lines) then
    begin
      ErrorDlg('No Lines Selected.');
      Exit;
    end;

    if Lines.Count = 0 then
    begin
      ErrorDlg('Selected Lines Empty.');
      Exit;
    end;

    // First pass: find // position for each line
    SetLength(CommentPos, Lines.Count);
    FirstCommentIdx := -1;

    for I := 0 to Lines.Count - 1 do
    begin
      ALine := Lines[I];
      CommentPos[I] := Pos('//', ALine);
      if (CommentPos[I] > 0) and (FirstCommentIdx = -1) then
        FirstCommentIdx := I;
    end;

    // No comment found
    if FirstCommentIdx = -1 then
    begin
      ErrorDlg('No // Comments Found in Selected Lines.');
      Exit;
    end;

    // Use first line's // position as base alignment position
    TargetPos := CommentPos[FirstCommentIdx];

    // Check if any line's code extends past target position
    for I := 0 to Lines.Count - 1 do
    begin
      if CommentPos[I] > 0 then
      begin
        ALine := Lines[I];
        // Trim trailing spaces before //
        CodeLen := CommentPos[I] - 1;
        while (CodeLen > 0) and (ALine[CodeLen] = ' ') do
          Dec(CodeLen);
        // Ensure at least 1 space between code and //
        if CodeLen + 1 > TargetPos then
          TargetPos := CodeLen + 1;
      end;
    end;

    // Second pass: realign comments
    for I := 0 to Lines.Count - 1 do
    begin
      if CommentPos[I] > 0 then
      begin
        ALine := Lines[I];

        // Extract code part (trimmed trailing spaces)
        CodeLen := CommentPos[I] - 1;
        while (CodeLen > 0) and (ALine[CodeLen] = ' ') do
          Dec(CodeLen);
        CodePart := Copy(ALine, 1, CodeLen);

        // Extract comment part (including // and everything after)
        CommentPart := Copy(ALine, CommentPos[I], Length(ALine));

        // Rebuild line: code + padding spaces + comment
        Lines[I] := CodePart + StringOfChar(' ', TargetPos - CodeLen) + CommentPart;
      end;
    end;

    IdeSetEditorSelectedLines(Lines);
  finally
    Lines.Free;
  end;
end.
